#include <iostream>

using namespace std;

int main() {
    int n;
    
   
    if (cin >> n) {
        
        if (n <= 0) return 0;

        int* arr = new int[n];
        for (int i = 0; i < n; i++) {
            cin >> arr[i];
        }

        
        cout << arr[0];

        
        for (int i = 1; i < n; i++) {
            bool isDuplicate = false;
            
            
            for (int j = 0; j < i; j++) {
                if (arr[i] == arr[j]) {
                    isDuplicate = true;
                    break;
                }
            }

            if (!isDuplicate) {
                cout << " " << arr[i];
            }
        }
        cout << endl;

      
        delete[] arr;
    }
    
    return 0;
}
