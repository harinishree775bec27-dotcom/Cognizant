
#include <iostream>

using namespace std;


long long findGCD(long long a, long long b) {
    while (b != 0) {
        long long temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}


long long findLCM(long long a, long long b) {
    if (a == 0 || b == 0) return 0;
    
    return (a / findGCD(a, b)) * b;
}

int main() {
    long long a, b, c;
    
 
    if (cin >> a >> b >> c) {
        
        
        long long lcm_ab = findLCM(a, b);
        
   
        long long final_lcm = findLCM(lcm_ab, c);
  
        cout << final_lcm << endl;
    }
    
    return 0;
}
