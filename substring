#include <iostream>
#include <string>
using namespace std;

int main() {
    string s1, s2;

    
    cin >> s1 >> s2;

    int i = 0; 
    int j = 0; 

    while (i < s1.length() && j < s2.length()) {
    
        if (s1[i] == s2[j]) {
            i++;
        }
        
        j++;
    }

    
    int resultFlag = 0; 
    if (i == s1.length()) {
        resultFlag = 1;
    }

    
    if (resultFlag == 1) {
        cout << "True\n";
    } else {
        cout << "False\n";
    }

    return 0;
}


