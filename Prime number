#include<iostream>
using namespace std;

int main(){
    
    
    int n, count =0 ;
    cout<<"Enter the value n:\n";
    cin >> n;
 
    for (int i=1;i<=n;i++){
        if(n%i==0){
            count++;
        }
    }if(count==2){
        cout<<"Its a Prime a number\n";
    }
    else{
        cout<<"Its not a prime number\n";
    }
}
